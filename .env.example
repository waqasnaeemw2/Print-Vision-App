# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# WORDPRESS CONFIGURATION (Optional: Can also be configured dynamically in the UI)
WORDPRESS_URL=https://your-wordpress-site.com
WORDPRESS_USER=admin
WORDPRESS_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ADMIN SECURITY & PERSISTENCE
# Set this password to restrict access to the Admin Panel. Refuses to boot if not set.
ADMIN_PASSWORD=printvision2026

# TRANSACTIONAL EMAIL DELIVERY (Resend.com API Key)
# Required to send real emails to info@printvisionpk.com when contacts submit inquiries.
RESEND_API_KEY=


